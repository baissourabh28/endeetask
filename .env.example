ENDEE_URL=http://localhost:8080
ENDEE_AUTH_TOKEN=

# --- LLM (all optional) ---
# Option 1: Ollama — free, runs locally. Install from https://ollama.com
#   then run: ollama pull llama3.2
#   Set OLLAMA_MODEL to enable. Leave empty to skip.
OLLAMA_MODEL=
OLLAMA_URL=http://localhost:11434

# Option 2: OpenAI — requires a paid API key
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# --- App settings ---
INDEX_NAME=rag_docs
EMBED_MODEL=all-MiniLM-L6-v2
TOP_K=5
